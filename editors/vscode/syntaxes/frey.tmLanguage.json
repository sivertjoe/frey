{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Frey",
  "scopeName": "source.frey",
  "patterns": [
    { "include": "#comments" },
    { "include": "#comptime" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#generics" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#calls" },
    { "include": "#type-names" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.frey", "match": "//.*$" },
        { "include": "#block-comment" }
      ]
    },
    "block-comment": {
      "comment": "Block comments nest, mirroring the lexer.",
      "name": "comment.block.frey",
      "begin": "/\\*",
      "end": "\\*/",
      "patterns": [{ "include": "#block-comment" }]
    },
    "comptime": {
      "name": "keyword.control.directive.comptime.frey",
      "match": "#\\s*comptime\\b"
    },
    "declarations": {
      "patterns": [
        {
          "comment": "Struct type definition: `let Name = struct`",
          "match": "\\b(let)\\b\\s+([A-Za-z_]\\w*)\\s*(=)\\s*(?=struct\\b)",
          "captures": {
            "1": { "name": "keyword.other.let.frey" },
            "2": { "name": "entity.name.type.frey" },
            "3": { "name": "keyword.operator.assignment.frey" }
          }
        },
        {
          "comment": "Function definition: `let [mut] name = (` or `let name = <..>(`",
          "match": "\\b(let)\\b\\s+(?:(mut)\\s+)?([A-Za-z_]\\w*)\\s*(=)\\s*(?=(?:<[^>;{}]*>\\s*)?\\()",
          "captures": {
            "1": { "name": "keyword.other.let.frey" },
            "2": { "name": "keyword.other.mut.frey" },
            "3": { "name": "entity.name.function.frey" },
            "4": { "name": "keyword.operator.assignment.frey" }
          }
        },
        {
          "comment": "Variable binding: `let [mut] name`",
          "match": "\\b(let)\\b\\s+(?:(mut)\\s+)?([A-Za-z_]\\w*)",
          "captures": {
            "1": { "name": "keyword.other.let.frey" },
            "2": { "name": "keyword.other.mut.frey" },
            "3": { "name": "variable.other.frey" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.frey",
          "match": "\\b(if|else|while|return|break|defer)\\b"
        },
        { "name": "keyword.other.frey", "match": "\\b(let|mut|struct|as|import)\\b" }
      ]
    },
    "types": {
      "name": "storage.type.builtin.frey",
      "match": "\\b(Int|UInt|Float|i8|i32|i64|u8|u32|u64|f32|f64)\\b"
    },
    "builtins": {
      "comment": "Compiler intrinsics.",
      "name": "support.function.builtin.frey",
      "match": "\\b(alloc|realloc|free|comperror)\\b"
    },
    "generics": {
      "comment": "Type parameters: `$T`.",
      "name": "entity.name.type.parameter.frey",
      "match": "\\$[A-Za-z_]\\w*"
    },
    "strings": {
      "name": "string.quoted.double.frey",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.frey", "match": "\\\\." }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.frey",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.float.frey",
          "match": "\\b\\d+[eE][+-]?\\d+\\b"
        },
        { "name": "constant.numeric.integer.frey", "match": "\\b\\d+\\b" }
      ]
    },
    "calls": {
      "comment": "Function / method call: `name(` or `name<..>(`.",
      "patterns": [
        {
          "name": "entity.name.function.call.frey",
          "match": "\\b([A-Za-z_]\\w*)\\s*(?=(?:<[^>;{}]*>\\s*)?\\()"
        }
      ]
    },
    "type-names": {
      "comment": "Capitalized identifiers are treated as types (Vec, List, Map, ...).",
      "name": "entity.name.type.frey",
      "match": "\\b[A-Z]\\w*\\b"
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.arrow.frey", "match": "->" },
        { "name": "keyword.operator.pipe.frey", "match": "\\|>" },
        {
          "name": "keyword.operator.frey",
          "match": "==|!=|<=|>=|&&|\\|\\||<<|>>"
        },
        { "name": "keyword.operator.frey", "match": "[-+*/%<>=!&|^]" }
      ]
    }
  }
}
